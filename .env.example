# Скопируйте в .env и заполните под себя. .env — в .gitignore.

# БД (дефолт можно не задавать)
DATABASE_URL=sqlite:///./app.db

# Логирование
LOG_LEVEL=INFO

# Нужны только для `make data` (загрузка ERA5/Sentinel-1).
# App/inference контейнеру они не нужны.
CDS_API_KEY=
COPERNICUS_TOKEN=

# Трекинг MLflow (нужен только для `make train` / `make eval`).
MLFLOW_TRACKING_URI=file://./mlruns
